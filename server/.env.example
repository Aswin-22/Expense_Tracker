# Server
PORT=3000

# Database
# Local: mongodb://127.0.0.1:27017/your-db-name
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/your-db-name
MONGO_URI=your_mongodb_connection_string

# Auth
# Generate a strong random string — never use a real word in production
JWT_SECRET=your_jwt_secret_key

# Environment
# Options: development | production
NODE_ENV=development